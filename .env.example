# StoryWeaver Engine — Environment Variables

# llama.cpp server endpoint
LLAMACPP_BASE_URL=http://localhost:8080/v1

# Data paths (override defaults from configs/default.yaml)
# SW_DATA_DIR=./data
# SW_CACHE_DIR=./data/cache

# Logging
# SW_LOG_LEVEL=INFO   # DEBUG, INFO, WARNING, ERROR
# SW_LOG_FILE=logs/storyweaver.log

# Development
# SW_EXTRACTION_DRY_RUN=false   # Set true to skip LLM calls during dev
